# Aviary Development Environment Variables
# Copy to .env or pass via docker-compose env_file for local development.

# ── Shared ───────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://aviary:aviary@localhost:5432/aviary
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=dev-root-token

# ── API Server ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
OIDC_ISSUER=http://localhost:8080/realms/aviary
OIDC_INTERNAL_ISSUER=http://keycloak:8080/realms/aviary
OIDC_CLIENT_ID=aviary-web
AGENT_SUPERVISOR_URL=http://localhost:9000
LITELLM_URL=http://litellm:4000
LITELLM_API_KEY=sk-aviary-dev
MCP_GATEWAY_URL=http://mcp-gateway:8100
INTERNAL_API_KEY=sk-aviary-internal

# ── Admin Console ────────────────────────────────────────────
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=aviary

# ── Agent Supervisor ────────────────────────────────────────
HOST_GATEWAY_IP=172.17.0.1
