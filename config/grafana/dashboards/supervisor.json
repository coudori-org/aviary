{
  "title": "Aviary Supervisor",
  "uid": "aviary-supervisor",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "editable": true,
  "tags": ["aviary", "supervisor"],
  "panels": [
    {
      "type": "stat",
      "title": "Active Streams",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "sum(aviary_supervisor_active_streams)", "refId": "A" }
      ],
      "options": { "colorMode": "value", "graphMode": "area" }
    },
    {
      "type": "stat",
      "title": "Active A2A Streams",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "sum(aviary_supervisor_active_a2a_streams)", "refId": "A" }
      ],
      "options": { "colorMode": "value", "graphMode": "area" }
    },
    {
      "type": "stat",
      "title": "Publish Error Ratio (5m)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(rate(aviary_supervisor_publish_requests_total{status=~\"error|disconnected\"}[5m])) / clamp_min(sum(rate(aviary_supervisor_publish_requests_total[5m])), 1e-9)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none" }
    },
    {
      "type": "stat",
      "title": "Publish Rate (req/s, 5m)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(rate(aviary_supervisor_publish_requests_total[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "type": "timeseries",
      "title": "Publish Requests by Status (rate/s)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (status) (rate(aviary_supervisor_publish_requests_total[1m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "drawStyle": "bars", "stacking": { "mode": "normal" } } }
      }
    },
    {
      "type": "timeseries",
      "title": "Publish Duration (p50 / p95 / p99)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(aviary_supervisor_publish_duration_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(aviary_supervisor_publish_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(aviary_supervisor_publish_duration_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "timeseries",
      "title": "Time to First Chunk (TTFB — p50/p95)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(aviary_supervisor_time_to_query_started_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(aviary_supervisor_time_to_query_started_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "timeseries",
      "title": "SSE Events by Type (rate/s)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (event_type) (rate(aviary_supervisor_sse_events_total[1m]))",
          "legendFormat": "{{event_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "cps" } }
    },
    {
      "type": "timeseries",
      "title": "Runtime HTTP Errors (rate/s)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "x": 0, "y": 20, "w": 8, "h": 7 },
      "targets": [
        {
          "expr": "sum by (status_code) (rate(aviary_supervisor_runtime_http_errors_total[5m]))",
          "legendFormat": "{{status_code}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "cps" } }
    },
    {
      "type": "timeseries",
      "title": "Abort Requests (rate/s)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "x": 8, "y": 20, "w": 8, "h": 7 },
      "targets": [
        {
          "expr": "sum by (via) (rate(aviary_supervisor_abort_requests_total[5m]))",
          "legendFormat": "{{via}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "cps" } }
    },
    {
      "type": "timeseries",
      "title": "External Deps — Vault p95 & Redis errors",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "x": 16, "y": 20, "w": 8, "h": 7 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(aviary_supervisor_vault_fetch_duration_seconds_bucket[5m])))",
          "legendFormat": "vault p95 (s)",
          "refId": "A"
        },
        {
          "expr": "sum(rate(aviary_supervisor_redis_errors_total[5m]))",
          "legendFormat": "redis errors (r/s)",
          "refId": "B"
        }
      ]
    }
  ]
}
