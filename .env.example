# ──────────────────────────────────────────────────────────────────────
# Single source of truth for both compose stacks.
# `local-infra/.env` is a symlink to this file (created by setup-dev.sh).
# Copy to `.env` and fill in what you need.
# ──────────────────────────────────────────────────────────────────────


# ══ Aviary services (root compose) ═══════════════════════════════════
# api, admin, agent-supervisor, workflow-worker, web

# DEV_USER_SUB=dev-user

# OIDC — leave OIDC_ISSUER unset for no-IdP dev mode (every caller is
# treated as DEV_USER_SUB). Frontend "Sign in" mints a session for that
# user immediately. Examples below for Keycloak / Auth0.
#
# Local Keycloak (provisioned by the local-infra stack):
# OIDC_ISSUER=http://localhost:8080/realms/aviary
# OIDC_INTERNAL_ISSUER=http://host.docker.internal:8080/realms/aviary
# OIDC_CLIENT_ID=aviary-web
#
# Hosted Auth0 / Okta (confidential client):
# OIDC_ISSUER=https://<tenant>.us.auth0.com
# OIDC_CLIENT_ID=<app-client-id>
# OIDC_CLIENT_SECRET=<app-client-secret>

# LLM / MCP gateway. Unset LLM_GATEWAY_URL → direct mode (config.yaml).
# LLM_GATEWAY_URL=http://host.docker.internal:8090
# LLM_GATEWAY_API_KEY=sk-aviary-dev
# MCP_GATEWAY_URL=http://host.docker.internal:8090
# MCP_GATEWAY_API_KEY=sk-aviary-dev

# Vault — leave both empty to fall back to config.yaml `secrets:` block.
# Set both to point at a real Vault if you want Vault-backed credentials.
# VAULT_ADDR=http://host.docker.internal:8200
# VAULT_TOKEN=dev-root-token

# Build / registry overrides
# UV_INDEX_URL=https://artifactory.example.com/api/pypi/simple/
# NPM_CONFIG_REGISTRY=https://artifactory.example.com/api/npm/npm-remote/

# Misc service overrides
# COOKIE_SECURE=true                       # false only for non-localhost dev
# DATABASE_URL=postgresql+asyncpg://aviary:aviary@host.docker.internal:5432/aviary
# REDIS_URL=redis://host.docker.internal:6379/0
# AGENT_SUPERVISOR_URL=http://supervisor:9000
# SUPERVISOR_URL=http://supervisor:9000
# INTERNAL_API_URL=http://api:8000
# SUPERVISOR_DEFAULT_RUNTIME_ENDPOINT=http://host.docker.internal:30300
# WORKER_SHARED_SECRET=dev-worker-secret-change-me
# TEMPORAL_HOST=host.docker.internal:7233
# NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Supervisor OTel metric push — disabled by default. Uncomment to send to
# the bundled local-infra collector (Prometheus + Grafana auto-provisioned).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://host.docker.internal:4318
# OTEL_SERVICE_NAME=aviary-supervisor


# ══ Local-infra ══════════════════════════════════════════════════════
# mcp-jira, mcp-confluence, litellm, grafana, llama-swap host script

# JIRA_BASE_URL=https://your-corp.atlassian.net
# CONFLUENCE_BASE_URL=https://your-corp.atlassian.net
# HF_TOKEN=hf_...

# Atlassian API variant per backend. `cloud` (default) → REST v3 + ADF /
# Confluence v2. Switch to `legacy` for on-prem Server / Data Center.
# JIRA_API_VARIANT=cloud
# CONFLUENCE_API_VARIANT=cloud

# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-northeast-2

# LITELLM_UI_USERNAME=admin
# LITELLM_UI_PASSWORD=admin
# LITELLM_SITE_PACKAGES=/usr/lib/python3.13/site-packages

# GRAFANA_ADMIN_PASSWORD=admin
