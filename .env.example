# ── Package Registries (for corporate/air-gapped environments) ──
# Leave empty to use public defaults (pypi.org, registry.npmjs.org)
#UV_INDEX_URL=https://artifactory.example.com/api/pypi/simple/
#NPM_CONFIG_REGISTRY=https://artifactory.example.com/api/npm/npm-remote/

# Database
DATABASE_URL=postgresql+asyncpg://aviary:aviary@localhost:5432/aviary

# Redis
REDIS_URL=redis://localhost:6379/0

# OIDC (Keycloak local dev)
OIDC_ISSUER=http://localhost:8080/realms/aviary
OIDC_CLIENT_ID=aviary-web

# Vault
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=dev-root-token

# K8s
KUBECONFIG=./kubeconfig.yaml

# Agent Runtime
AGENT_RUNTIME_IMAGE=aviary-runtime:latest

# Inference backends
ANTHROPIC_API_KEY=sk-ant-...
OLLAMA_URL=http://localhost:11434
VLLM_URL=http://localhost:8191

# HuggingFace
HF_TOKEN=hf_...

# vLLM standalone container (used by scripts/run-vllm.sh)
VLLM_PORT=8191
VLLM_MODEL=cyankiwi/gemma-4-31B-it-AWQ-4bit
VLLM_IMAGE=vllm/vllm-openai:gemma4
VLLM_GPU_MEM=0.90
VLLM_MAX_MODEL_LEN=131072
VLLM_MAX_NUM_SEQS=5

# CORS
CORS_ORIGINS=http://localhost:3000
