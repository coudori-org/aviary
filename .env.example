# UV_INDEX_URL=https://artifactory.example.com/api/pypi/simple/
# NPM_CONFIG_REGISTRY=https://artifactory.example.com/api/npm/npm-remote/

# Set false only for non-localhost dev access (LAN IP, host.docker.internal).
# COOKIE_SECURE=true

# DATABASE_URL=postgresql+asyncpg://aviary:aviary@host.docker.internal:5432/aviary
# REDIS_URL=redis://host.docker.internal:6379/0
# LITELLM_URL=http://host.docker.internal:8090
# LITELLM_API_KEY=sk-aviary-dev
# TEMPORAL_HOST=host.docker.internal:7233
# VAULT_ADDR=http://host.docker.internal:8200
# VAULT_TOKEN=dev-root-token

# ── OIDC ─────────────────────────────────────────────────────────────────
#
# Leave OIDC_ISSUER unset to run without a real IdP — every request is
# treated as DEV_USER_SUB (default: "dev-user"). The frontend "Sign in"
# button immediately mints a session for that user.
#
# To enable a real IdP, set OIDC_ISSUER + OIDC_CLIENT_ID (and
# OIDC_CLIENT_SECRET for confidential clients like Okta). Examples below.
#
# DEV_USER_SUB=dev-user
#
# Local Keycloak (the dev-up.sh stack provisions this realm):
# OIDC_ISSUER=http://localhost:8080/realms/aviary
# OIDC_INTERNAL_ISSUER=http://host.docker.internal:8080/realms/aviary
# OIDC_CLIENT_ID=aviary-web
#
# Hosted Okta (confidential client):
# OIDC_ISSUER=https://<tenant>.okta.com/oauth2/default
# OIDC_CLIENT_ID=<okta-app-client-id>
# OIDC_CLIENT_SECRET=<okta-app-client-secret>
# OIDC_AUDIENCE=<api-audience>     # optional

# AGENT_SUPERVISOR_URL=http://supervisor:9000
# SUPERVISOR_URL=http://supervisor:9000
# INTERNAL_API_URL=http://api:8000

# SUPERVISOR_DEFAULT_RUNTIME_ENDPOINT=http://host.docker.internal:30300

# WORKER_SHARED_SECRET=dev-worker-secret-change-me

# NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_WS_URL=ws://localhost:8000
