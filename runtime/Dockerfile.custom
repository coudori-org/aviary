# Template for building a customized runtime image on top of the base.
# Used by the `custom` Helm environment; copy + edit this file (and the
# corresponding values-<name>.yaml) when you need a differently-provisioned
# environment. Everything else — sandbox wrapper, Claude SDK, Python venv
# bootstrap — is inherited verbatim from the base image.
#
# Add whatever your environment needs the same way `cowsay` is installed
# below.

FROM aviary-runtime:latest

USER root
RUN apt-get update && apt-get install -y --no-install-recommends cowsay \
    && rm -rf /var/lib/apt/lists/* \
    && ln -s /usr/games/cowsay /usr/local/bin/cowsay
USER node
